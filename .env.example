MNEMOS_ENV=development
MNEMOS_HOST=0.0.0.0
MNEMOS_PORT=8000
MNEMOS_LOG_LEVEL=INFO
MNEMOS_URL=http://localhost:8000
MNEMOS_TIMEOUT_SECONDS=10
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=9000
MCP_SERVER_TRANSPORT=stdio

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mnemos
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

QDRANT_URL=http://localhost:6333
QDRANT_VECTOR_SIZE=64

EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=mock-embedding
EMBEDDING_BASE_URL=http://host.docker.internal:11434/v1
EMBEDDING_API_KEY=
FACT_LLM_PROVIDER=mock
FACT_LLM_MODEL=mock-fact-llm
FACT_LLM_BASE_URL=http://host.docker.internal:11434/v1
FACT_LLM_API_KEY=
FACT_LLM_TIMEOUT_SECONDS=20
FACT_MAX_FACTS_PER_ITEM=5
FACT_MIN_CHARS=10
FACT_MAX_CHARS=300
REFLECTION_LLM_PROVIDER=mock
REFLECTION_LLM_MODEL=mock-reflection-llm
REFLECTION_LLM_BASE_URL=http://host.docker.internal:11434/v1
REFLECTION_LLM_API_KEY=
REFLECTION_LLM_TIMEOUT_SECONDS=20
REFLECTION_MAX_PER_THEME=5
REFLECTION_MIN_CHARS=20
REFLECTION_MAX_CHARS=300
