MNEMOS_ENV=development
MNEMOS_LOG_LEVEL=INFO
MNEMOS_TIMEOUT_SECONDS=10

POSTGRES_DB=mnemos
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

QDRANT_VECTOR_SIZE=1536

EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
EMBEDDING_API_KEY=
EMBEDDING_TIMEOUT_SECONDS=10
FACT_LLM_MODEL=openai/gpt-4.1-mini
FACT_LLM_BASE_URL=https://openrouter.ai/api/v1
FACT_LLM_API_KEY=
FACT_LLM_TIMEOUT_SECONDS=20
FACT_MAX_FACTS_PER_ITEM=5
FACT_MIN_CHARS=10
FACT_MAX_CHARS=300
REFLECTION_LLM_MODEL=openai/gpt-4.1-mini
REFLECTION_LLM_BASE_URL=https://openrouter.ai/api/v1
REFLECTION_LLM_API_KEY=
REFLECTION_LLM_TIMEOUT_SECONDS=20
REFLECTION_MAX_PER_THEME=5
REFLECTION_MIN_CHARS=20
REFLECTION_MAX_CHARS=300
